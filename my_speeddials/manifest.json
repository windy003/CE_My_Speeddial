{
  "manifest_version": 3,
  "name": "My Speed Dial",
  "version": "1.0.0",
  "description": "A customizable speed dial for new tabs",
  "permissions": ["bookmarks", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
